// =========================================================================
// slim_sim_n_traits.slim
//
// SLiM 5.2 simulation for "Additive Channels in Curved Fitness Landscapes"
// (Ortiz-Barrientos & Cooper, GENETICS-2026-309068).
//
// Generalisation of slim_sim.slim to:
//   1. ARBITRARY NUMBER OF TRAITS (configurable via N_TRAITS).
//      The original 2-trait PoC corresponds to N_TRAITS = 2.
//   2. TIME-VARYING OPTIMUM (z*(t)).  An initial vector Z_OPT_INITIAL drifts
//      linearly at velocity DRIFT_VELOCITY for cycles 1..DRIFT_END_GEN, then
//      remains fixed.  Setting DRIFT_VELOCITY = 0 (a zero vector) recovers the
//      static-optimum behaviour of the original PoC.
//
// MOTIVATION FOR THE MOVING-OPTIMUM CASE:
//   With a fixed optimum, the population catches up quickly, |b| collapses
//   to zero, V_lin -> 0, and A_g falls monotonically (the "fall-only" PoC
//   trajectory).  With a drifting optimum, the population settles into a
//   LAG EQUILIBRIUM where δ_eq = v/(γG) and |b|_eq = v/G.  As the Bulmer
//   effect compresses G during sustained directional selection, δ_eq grows,
//   |b|_eq grows, V_lin = |b|^2 G = v^2/G *grows*, and V_quad = 0.5 (γG)^2
//   *shrinks*.  A_g RISES during this phase.  When the drift ends, |b|
//   decays exponentially and A_g falls.  This is the rise-then-fall
//   trajectory that's invisible in the static-optimum case.
//
// MUTATION DESIGN:
//   Each mutation carries two attribute slots:
//     - "trait_idx" : integer 0..N_TRAITS-1, which trait the locus affects
//     - "eff"       : scalar effect of the mutation on that trait
//   No pleiotropy: each locus affects exactly one trait.  Loci are grouped:
//   the first L_PER_TRAIT loci affect trait 1, the next L_PER_TRAIT affect
//   trait 2, etc.  Free recombination between every locus pair.
//
// USAGE:
//   slim \
//     -d "OUTPUT_PATH='output/rep_bv.csv'" \
//     -d "OPTIMUM_PATH='output/rep_opt.csv'" \
//     -d "SEED=42" \
//     -d "N_TRAITS=4" \
//     -d "SIGMAS=c(0.346, 0.283, 0.200, 0.141)" \
//     -d "GAMMAS=c(0.10, 0.05, 0.04, 0.03)" \
//     -d "Z_OPT_INITIAL=c(0.0, 0.0, 0.0, 0.0)" \
//     -d "DRIFT_VELOCITY=c(0.3, 0.0, 0.0, 0.0)" \
//     -d "DRIFT_END_GEN=40" \
//     slim_sim_n_traits.slim
//
// =========================================================================

initialize()
{
    // ------------------- Defaults (overridable via -d) -------------------

    if (!exists("SEED"))           defineConstant("SEED", 42);
    setSeed(SEED);

    if (!exists("OUTPUT_PATH"))
        defineConstant("OUTPUT_PATH",  "output/rep_default_bv.csv");
    if (!exists("OPTIMUM_PATH"))
        defineConstant("OPTIMUM_PATH", "output/rep_default_opt.csv");

    if (!exists("N"))              defineConstant("N", 2000);
    if (!exists("GENS"))           defineConstant("GENS", 200);
    if (!exists("L_PER_TRAIT"))    defineConstant("L_PER_TRAIT", 50);
    if (!exists("N_TRAITS"))       defineConstant("N_TRAITS", 4);

    // Per-trait per-locus effect SDs.  Defaults give G_0 = diag(3, 2, 1, 0.5)
    // at HWE (since G_kk ~ L_PER_TRAIT * 0.5 * SIGMAS[k]^2 with p=0.5).
    if (!exists("SIGMAS"))
        defineConstant("SIGMAS", c(0.346, 0.283, 0.200, 0.141));

    // Per-trait stabilising-selection magnitudes (diagonal Gamma).
    if (!exists("GAMMAS"))
        defineConstant("GAMMAS", c(0.10, 0.05, 0.04, 0.03));

    // Initial optimum (length N_TRAITS).
    if (!exists("Z_OPT_INITIAL"))
        defineConstant("Z_OPT_INITIAL", c(0.0, 0.0, 0.0, 0.0));

    // Drift velocity per trait per generation (length N_TRAITS).
    // Set all components to 0 to recover the static-optimum case.
    if (!exists("DRIFT_VELOCITY"))
        defineConstant("DRIFT_VELOCITY", c(0.3, 0.0, 0.0, 0.0));

    // Cycle at which drift stops (drift acts in cycles 1..DRIFT_END_GEN
    // inclusive, then optimum is fixed at its drifted endpoint).
    if (!exists("DRIFT_END_GEN"))  defineConstant("DRIFT_END_GEN", 40);

    defineConstant("N_LOCI", N_TRAITS * L_PER_TRAIT);

    // -------------------------- Genomic setup ---------------------------

    initializeMutationType("m1", 0.5, "f", 0.0);
    m1.convertToSubstitution = F;

    initializeGenomicElementType("g1", m1, 1.0);
    initializeGenomicElement(g1, 0, N_LOCI - 1);

    initializeMutationRate(0);
    initializeRecombinationRate(0.5);
}


// =========================================================================
//  Helper: time-varying optimum
//  Returns the optimum vector at a given cycle.
// =========================================================================

function (numeric)currentOptimum(integer$ cycle)
{
    if (DRIFT_END_GEN <= 0)
        return Z_OPT_INITIAL;

    steps = min(cycle - 1, DRIFT_END_GEN);
    return Z_OPT_INITIAL + DRIFT_VELOCITY * steps;
}


// =========================================================================
//  TICK 1, EARLY: create the empty population
// =========================================================================

1 early()
{
    sim.addSubpop("p1", N);
}


// =========================================================================
//  TICK 1, LATE: place QTLs, open output files
//  Effects centred per trait so initial population mean BV = (0,0,...,0).
// =========================================================================

1 late()
{
    haps = p1.haplosomes;
    n_haps = length(haps);

    // Place QTLs trait-by-trait; effects are centred per trait so the
    // initial population mean BV is zero by construction (modulo HWE).
    for (k in seqLen(N_TRAITS))
    {
        sigma_k = SIGMAS[k];
        eff_k = rnorm(L_PER_TRAIT, 0, sigma_k);
        eff_k = eff_k - mean(eff_k);  // centre

        for (j in seqLen(L_PER_TRAIT))
        {
            i = k * L_PER_TRAIT + j;  // global locus position
            target = sample(haps, asInteger(n_haps * 0.5));
            new_mut = target.addNewDrawnMutation(m1, asInteger(i));
            new_mut.setValue("trait_idx", k);
            new_mut.setValue("eff", eff_k[j]);
        }
    }

    // ---- Initialise BV output file ----
    bv_header = "generation,individual";
    for (k in seqLen(N_TRAITS))
        bv_header = bv_header + ",a" + asString(k + 1);
    writeFile(OUTPUT_PATH, bv_header);

    // ---- Initialise optimum output file ----
    opt_header = "generation";
    for (k in seqLen(N_TRAITS))
        opt_header = opt_header + ",z_opt_" + asString(k + 1);
    writeFile(OPTIMUM_PATH, opt_header);

    // ---- Console summary ----
    catn("Initial population: " + N + " diploids");
    catn("Number of traits: " + N_TRAITS);
    catn("Loci per trait: " + L_PER_TRAIT + ", total QTLs: " + N_LOCI);
    catn("Per-trait effect SDs: " + paste(SIGMAS, sep=", "));
    catn("Stabilising selection (gammas): " + paste(GAMMAS, sep=", "));
    catn("Initial optimum: " + paste(Z_OPT_INITIAL, sep=", "));
    catn("Drift velocity: " + paste(DRIFT_VELOCITY, sep=", "));
    catn("Drift end cycle: " + DRIFT_END_GEN);
    catn("BV output:      " + OUTPUT_PATH);
    catn("Optimum output: " + OPTIMUM_PATH);
}


// =========================================================================
//  PER-INDIVIDUAL FITNESS
//
//  log W(z) = -0.5 sum_k gamma_k (z_k - z*_k(t))^2
//
//  Uses currentOptimum(sim.cycle) so the fitness landscape moves with the
//  optimum.  Phenotype = breeding value (E = 0).
// =========================================================================

fitnessEffect()
{
    muts = individual.haplosomes.mutations;

    if (length(muts) == 0)
        return 1.0;

    idx_vec = muts.getValue("trait_idx");
    eff_vec = muts.getValue("eff");

    // Compute per-trait BV by summing effects of mutations with that trait_idx
    bv = float(N_TRAITS);
    for (k in seqLen(N_TRAITS))
        bv[k] = sum(eff_vec[idx_vec == k]);

    z_opt = currentOptimum(sim.cycle);
    dx = bv - z_opt;
    log_W = -0.5 * sum(GAMMAS * dx * dx);
    return exp(log_W);
}


// =========================================================================
//  LOG BVs and CURRENT OPTIMUM EACH GENERATION
// =========================================================================

1: late()
{
    inds = p1.individuals;
    n = length(inds);
    gen = sim.cycle;

    // ---- Per-individual BV lines ----
    lines = string(n);
    for (i in seqLen(n))
    {
        muts = inds[i].haplosomes.mutations;
        line = gen + "," + i;

        if (length(muts) == 0)
        {
            for (k in seqLen(N_TRAITS))
                line = line + ",0";
        }
        else
        {
            idx_vec = muts.getValue("trait_idx");
            eff_vec = muts.getValue("eff");
            for (k in seqLen(N_TRAITS))
            {
                bv_k = sum(eff_vec[idx_vec == k]);
                line = line + "," + bv_k;
            }
        }
        lines[i] = line;
    }
    writeFile(OUTPUT_PATH, lines, append=T);

    // ---- One optimum row for this generation ----
    z_opt = currentOptimum(gen);
    opt_line = "" + gen;
    for (k in seqLen(N_TRAITS))
        opt_line = opt_line + "," + z_opt[k];
    writeFile(OPTIMUM_PATH, opt_line, append=T);
}


// =========================================================================
//  STOP AT GENS
// =========================================================================

GENS late()
{
    catn("Done: " + GENS + " generations completed.");
    sim.simulationFinished();
}
